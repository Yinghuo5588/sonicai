TZ=Asia/Shanghai

# Database —复用已有 PostgreSQL 容器
DATABASE_URL=postgresql+psycopg://musicrec_user:strong_password@emby-postgres:5432/musicrec

# Redis —复用已有 Redis 容器
REDIS_URL=redis://emby-redis:6379/3
REDIS_KEY_PREFIX=sonicai:

# 初始管理员（首次启动时自动创建）
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=your_secure_password_here
INIT_ADMIN_EMAIL=admin@sonicai.local

# JWT 密钥（请在生产环境替换为随机字符串）
JWT_SECRET_KEY=sonicai-access-secret-2026-change-me
JWT_REFRESH_SECRET_KEY=sonicai-refresh-secret-2026-change-me

# 应用
APP_TIMEZONE=Asia/Shanghai
FRONTEND_ORIGIN=http://localhost:5173

# Nginx
NGINX_PORT=5173